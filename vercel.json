{
  "version": 2,
  "functions": {
    "api/**/*.cjs": {
      "includeFiles": [
        "backend/database/rotilezat.db",
        "node_modules/better-sqlite3/**/*.node"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
